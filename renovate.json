{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "America/Chicago",
  "ignorePaths": [
    "flux/apps/wailord/game-svcss/**"
  ],
  "extends": [
    "config:recommended"
  ],
    "flux": {
    "managerFilePatterns": ["/flux/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true,
      "automergeSchedule": [
        "after 11pm",
        "before 5am"
      ],
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "values.yaml"
      ],
      "matchStrings": [
        "repository: (?<depName>hotio\\/.*)\\n\\ *tag: \"release-(?<currentValue>.*)\"",
        "repository: (?<depName>hotio\\/.*)\\n\\ *tag: \"testing-(?<currentValue>.*)\""
      ],
      "extractVersionTemplate": "^release-(?<version>.*)$",
      "datasourceTemplate": "docker"
    }
  ],
  "enabled": true
}
